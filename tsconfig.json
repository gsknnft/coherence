{
    "compilerOptions": {
        "target": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ESNext"],
        "module": "ESNext",
        "declaration": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src", "src/attractors"],
    "exclude": ["node_modules", "dist"]
}
